{
  "version": "2.0",
  "default_pattern": "manager-worker",
  "protocol": "MAMIS/1",
  "principal_agents": [
    "CODEX",
    "KIMI"
  ],
  "naming": {
    "format": "<ROLE>-<CALLSIGN>-<ID>",
    "adjectives": [
      "amber",
      "cinder",
      "ivory",
      "jade",
      "lunar",
      "onyx",
      "quartz",
      "sable",
      "slate",
      "swift"
    ],
    "nouns": [
      "atlas",
      "beacon",
      "delta",
      "forge",
      "grid",
      "harbor",
      "node",
      "river",
      "signal",
      "vector"
    ]
  },
  "roles": [
    {
      "role": "WEB_SCOUT",
      "category": "external-intelligence",
      "can_write": false,
      "best_for": [
        "web research",
        "docs lookup",
        "benchmark lookup",
        "source gathering"
      ],
      "required_output": [
        "status",
        "summary",
        "evidence",
        "links",
        "risks"
      ]
    },
    {
      "role": "CODE_SCOUT",
      "category": "repo-intelligence",
      "can_write": false,
      "best_for": [
        "file discovery",
        "dependency tracing",
        "ownership mapping",
        "hotspot analysis"
      ],
      "required_output": [
        "status",
        "summary",
        "files",
        "evidence",
        "risks"
      ]
    },
    {
      "role": "SURGEON",
      "category": "implementation",
      "can_write": true,
      "best_for": [
        "bounded code changes",
        "bug fixes",
        "refactors with clear ownership"
      ],
      "required_output": [
        "status",
        "summary",
        "files",
        "risks",
        "next"
      ]
    },
    {
      "role": "VERIFIER",
      "category": "validation",
      "can_write": false,
      "best_for": [
        "build validation",
        "tests",
        "smoke checks",
        "regression checks"
      ],
      "required_output": [
        "status",
        "summary",
        "evidence",
        "risks"
      ]
    },
    {
      "role": "REVIEWER",
      "category": "quality",
      "can_write": false,
      "best_for": [
        "code review",
        "risk review",
        "test gap review"
      ],
      "required_output": [
        "status",
        "summary",
        "evidence",
        "risks",
        "next"
      ]
    },
    {
      "role": "SYNTHESIZER",
      "category": "consolidation",
      "can_write": false,
      "best_for": [
        "merge findings",
        "state consolidation",
        "final truth drafting"
      ],
      "required_output": [
        "status",
        "summary",
        "evidence",
        "next"
      ]
    }
  ],
  "spawn_policy": {
    "default_strategy": "aggressive-safe",
    "default_max_parallel": 3,
    "soft_max_parallel": 6,
    "hard_max_parallel": 12,
    "never_parallelize_same_file_writes": true,
    "prefer_single_agent_for_small_linear_tasks": true,
    "prefer_parallel_for_breadth_first_research": true,
    "prefer_maximum_safe_parallelism": true
  },
  "adaptive_scaling": {
    "strategies": {
      "conservative": {
        "max_parallel": 3,
        "research_web_scouts": 1,
        "research_code_scouts": 1,
        "implementation_surgeons": 1,
        "validation_verifiers": 1
      },
      "balanced": {
        "max_parallel": 6,
        "research_web_scouts": 2,
        "research_code_scouts": 2,
        "implementation_surgeons": 2,
        "validation_verifiers": 1
      },
      "aggressive-safe": {
        "max_parallel": 12,
        "research_web_scouts": 3,
        "research_code_scouts": 3,
        "implementation_surgeons": 3,
        "validation_verifiers": 2
      }
    }
  },
  "recursion_policy": {
    "allow_nested_delegation": true,
    "max_depth": 2,
    "max_children_per_agent": 3,
    "max_parallel_global": 6,
    "max_write_agents_per_parent": 1,
    "roles_allowed_to_delegate": [
      "WEB_SCOUT",
      "CODE_SCOUT",
      "REVIEWER",
      "SYNTHESIZER"
    ],
    "roles_never_delegate": [
      "SURGEON",
      "VERIFIER"
    ],
    "delegate_only_if": [
      "breadth_first_research",
      "context_partitioning",
      "independent_evidence_modes"
    ],
    "block_if": [
      "same_file_write_conflict",
      "unclear_ownership",
      "depth_exhausted",
      "branch_budget_exhausted"
    ]
  }
}
